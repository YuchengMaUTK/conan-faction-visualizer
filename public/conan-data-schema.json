{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "conan-data-schema.json",
  "title": "名侦探柯南 Entity-Persona-Link 数据集 / Detective Conan Entity-Persona-Link Dataset",
  "description": "名侦探柯南阵营可视化工具的完整数据集定义，基于 Entity-Persona-Link 三层嵌套结构。",
  "type": "object",
  "required": ["metadata", "entities", "characterEvents", "links", "relationshipEvents", "episodeChapterMappings", "storyArcs"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 引用路径"
    },
    "metadata": {
      "type": "object",
      "description": "数据集元信息 / Dataset metadata",
      "required": ["version", "lastUpdated", "totalEpisodes", "totalChapters"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "数据集版本号 / Dataset version (semver format)",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "lastUpdated": {
          "type": "string",
          "description": "最后更新日期 / Last updated date (YYYY-MM-DD format)",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "totalEpisodes": {
          "type": "integer",
          "description": "动画总集数 / Total anime episodes",
          "minimum": 0
        },
        "totalChapters": {
          "type": "integer",
          "description": "漫画总话数 / Total manga chapters",
          "minimum": 0
        }
      }
    },
    "entities": {
      "type": "array",
      "description": "实体列表 / Entity list",
      "items": { "$ref": "#/$defs/Entity" }
    },
    "characterEvents": {
      "type": "array",
      "description": "角色事件列表 / Character event list",
      "items": { "$ref": "#/$defs/CharacterEvent" }
    },
    "links": {
      "type": "array",
      "description": "关系边列表 / Link list",
      "items": { "$ref": "#/$defs/Link" }
    },
    "relationshipEvents": {
      "type": "array",
      "description": "关系事件列表 / Relationship event list",
      "items": { "$ref": "#/$defs/RelationshipEvent" }
    },
    "episodeChapterMappings": {
      "type": "array",
      "description": "集数-话数映射列表 / Episode-chapter mapping list",
      "items": { "$ref": "#/$defs/EpisodeChapterMapping" }
    },
    "storyArcs": {
      "type": "array",
      "description": "剧情篇章列表 / Story arc list",
      "items": { "$ref": "#/$defs/StoryArc" }
    }
  },

  "$defs": {
    "I18nName": {
      "type": "object",
      "description": "多语言名称，en 为必填主键 / Internationalized name, en is required",
      "required": ["en"],
      "properties": {
        "en": {
          "type": "string",
          "description": "英文名（必填，作为主键） / English name (required, primary key)"
        },
        "ja": {
          "type": "string",
          "description": "日文名（汉字） / Japanese name (kanji)"
        },
        "ja_romaji": {
          "type": "string",
          "description": "日文罗马字转写 / Japanese romanization"
        },
        "zh": {
          "type": "string",
          "description": "中文名 / Chinese name"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "FirstAppearance": {
      "type": "object",
      "description": "首次登场信息 / First appearance information",
      "additionalProperties": false,
      "properties": {
        "manga_file": {
          "type": "integer",
          "description": "漫画话数（File 编号） / Manga file number",
          "minimum": 0
        },
        "anime_episode": {
          "type": "integer",
          "description": "动画集数 / Anime episode number",
          "minimum": 0
        }
      }
    },
    "VoiceActors": {
      "type": "object",
      "description": "声优信息 / Voice actor information",
      "additionalProperties": false,
      "properties": {
        "ja": {
          "type": "string",
          "description": "日文声优 / Japanese voice actor"
        },
        "en": {
          "type": "string",
          "description": "英文声优 / English voice actor"
        }
      }
    },
    "Relative": {
      "type": "object",
      "description": "家庭关系 / Family relative",
      "required": ["entity_id", "relation"],
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "type": "string",
          "description": "关联的 Entity ID / Associated Entity ID",
          "pattern": "^e_"
        },
        "relation": {
          "type": "string",
          "description": "关系类型 / Relation type",
          "enum": ["parent", "child", "sibling", "spouse", "cousin", "grandparent", "grandchild", "uncle_aunt", "nephew_niece"]
        }
      }
    },

    "Persona": {
      "type": "object",
      "description": "身份/面具 — Entity 在不同阵营或社会场景下使用的身份 / Persona used by Entity in different factions or social contexts",
      "required": ["persona_id", "name", "faction", "avatar", "is_default_display"],
      "additionalProperties": false,
      "properties": {
        "persona_id": {
          "type": "string",
          "description": "唯一标识符，以 p_ 为前缀 / Unique identifier with p_ prefix",
          "pattern": "^p_"
        },
        "name": {
          "$ref": "#/$defs/I18nName",
          "description": "该身份使用的名称 / Name used by this persona"
        },
        "faction": {
          "type": "string",
          "description": "所属阵营 / Faction",
          "enum": ["RED", "BLACK", "OTHER"]
        },
        "sub_faction": {
          "type": "string",
          "description": "子阵营（可选） / Sub-faction (optional)"
        },
        "avatar": {
          "type": "string",
          "description": "头像 URL / Avatar URL"
        },
        "codename": {
          "type": ["string", "null"],
          "description": "代号（可选，如 Rye、Bourbon） / Codename (optional)"
        },
        "is_default_display": {
          "type": "boolean",
          "description": "是否为默认展示身份 / Whether this is the default display persona"
        },
        "description": {
          "$ref": "#/$defs/I18nName",
          "description": "简要描述（可选，如职业） / Brief description (optional)"
        }
      }
    },
    "Entity": {
      "type": "object",
      "description": "实体 — 物理意义上的同一个人 / Entity — the same physical person",
      "required": ["entity_id", "true_name", "status", "base_appearances", "personas"],
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "type": "string",
          "description": "唯一标识符，以 e_ 为前缀 / Unique identifier with e_ prefix",
          "pattern": "^e_"
        },
        "true_name": {
          "$ref": "#/$defs/I18nName",
          "description": "真实姓名 / True name"
        },
        "status": {
          "type": "string",
          "description": "角色状态 / Character status",
          "enum": ["alive", "dead", "unknown", "shrunk", "missing"]
        },
        "base_appearances": {
          "type": "integer",
          "description": "总出场次数 / Total appearance count",
          "minimum": 0
        },
        "personas": {
          "type": "array",
          "description": "身份列表，至少包含一个 / Persona list, at least one required",
          "items": { "$ref": "#/$defs/Persona" },
          "minItems": 1
        },
        "wiki_url": {
          "type": "string",
          "description": "Wiki 页面 URL / Wiki page URL",
          "format": "uri"
        },
        "nicknames": {
          "type": "array",
          "description": "昵称列表 / Nickname list",
          "items": { "$ref": "#/$defs/I18nName" }
        },
        "first_appearance": {
          "$ref": "#/$defs/FirstAppearance",
          "description": "首次登场信息 / First appearance information"
        },
        "voice_actors": {
          "$ref": "#/$defs/VoiceActors",
          "description": "声优信息 / Voice actor information"
        },
        "gender": {
          "type": "string",
          "description": "性别 / Gender",
          "enum": ["male", "female", "unknown"]
        },
        "age": {
          "type": ["integer", "null"],
          "description": "年龄（可选） / Age (optional)"
        },
        "relatives": {
          "type": "array",
          "description": "家庭关系 / Family relatives",
          "items": { "$ref": "#/$defs/Relative" }
        }
      }
    },

    "Link": {
      "type": "object",
      "description": "关系边 — 绑定在 Persona 之间 / Relationship link between Personas",
      "required": ["source_persona_id", "target_persona_id", "type", "label"],
      "additionalProperties": false,
      "properties": {
        "source_persona_id": {
          "type": "string",
          "description": "源 Persona ID / Source Persona ID",
          "pattern": "^p_"
        },
        "target_persona_id": {
          "type": "string",
          "description": "目标 Persona ID / Target Persona ID",
          "pattern": "^p_"
        },
        "type": {
          "type": "string",
          "description": "关系类型 / Link type",
          "enum": ["romantic", "family", "master_apprentice", "colleague", "rivalry", "friendship", "superior_subordinate"]
        },
        "label": {
          "$ref": "#/$defs/I18nName",
          "description": "显示标签 / Display label"
        },
        "status": {
          "type": "string",
          "description": "关系状态（可选） / Relationship status (optional)"
        }
      }
    },
    "CharacterEvent": {
      "type": "object",
      "description": "角色事件，记录角色状态变化 / Character event recording status changes",
      "required": ["id", "entity_id", "type", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "事件唯一标识符 / Unique event identifier"
        },
        "entity_id": {
          "type": "string",
          "description": "关联 Entity ID / Associated Entity ID",
          "pattern": "^e_"
        },
        "type": {
          "type": "string",
          "enum": ["JOIN", "LEAVE", "DEATH", "EXPOSED", "DEFECT"],
          "description": "事件类型 / Event type"
        },
        "episodeIndex": {
          "type": "integer",
          "description": "关联动画集数 / Associated anime episode index"
        },
        "chapterIndex": {
          "type": "integer",
          "description": "关联漫画话数 / Associated manga chapter index"
        },
        "description": {
          "type": "string",
          "description": "事件描述 / Event description"
        }
      }
    },
    "RelationshipEvent": {
      "type": "object",
      "description": "关系事件，记录关系状态变化 / Relationship event recording status changes",
      "required": ["id", "relationshipId", "newStatus", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "事件唯一标识符 / Unique event identifier",
          "minLength": 1
        },
        "relationshipId": {
          "type": "string",
          "description": "关联关系 ID / Associated relationship ID",
          "minLength": 1
        },
        "episodeIndex": {
          "type": "integer",
          "description": "关联动画集数 / Associated anime episode index",
          "minimum": 1
        },
        "chapterIndex": {
          "type": "integer",
          "description": "关联漫画话数 / Associated manga chapter index",
          "minimum": 1
        },
        "newStatus": {
          "type": "string",
          "enum": ["UNCONFESSED", "CONFESSED", "DATING", "CONFIRMED", "SEPARATED"],
          "description": "变更后的关系状态 / New relationship status"
        },
        "description": {
          "type": "string",
          "description": "事件描述 / Event description",
          "minLength": 1
        }
      }
    },
    "EpisodeChapterMapping": {
      "type": "object",
      "description": "集数-话数映射 / Episode-chapter mapping",
      "required": ["episodeIndex", "chapterIndex", "publicationDate"],
      "additionalProperties": false,
      "properties": {
        "episodeIndex": {
          "type": "integer",
          "description": "动画集数编号 / Anime episode index",
          "minimum": 1
        },
        "chapterIndex": {
          "type": "integer",
          "description": "漫画话数编号 / Manga chapter index",
          "minimum": 1
        },
        "publicationDate": {
          "type": "string",
          "description": "漫画发行日期 / Manga publication date (YYYY-MM format)",
          "pattern": "^\\d{4}-\\d{2}$"
        }
      }
    },
    "StoryArc": {
      "type": "object",
      "description": "剧情篇章 / Story arc",
      "required": ["id", "name", "description", "startEpisodeIndex", "startChapterIndex"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "篇章唯一标识符 / Unique arc identifier",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "description": "篇章名称 / Arc name",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "篇章简要描述 / Arc brief description",
          "minLength": 1
        },
        "startEpisodeIndex": {
          "type": "integer",
          "description": "起始动画集数 / Starting anime episode index",
          "minimum": 1
        },
        "startChapterIndex": {
          "type": "integer",
          "description": "起始漫画话数 / Starting manga chapter index",
          "minimum": 1
        },
        "endEpisodeIndex": {
          "type": "integer",
          "description": "结束动画集数（可选） / Ending anime episode index (optional)",
          "minimum": 1
        },
        "endChapterIndex": {
          "type": "integer",
          "description": "结束漫画话数（可选） / Ending manga chapter index (optional)",
          "minimum": 1
        }
      }
    }
  }
}